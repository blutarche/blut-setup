# https://ghostty.org/docs/config

# Theme (matches VSCode Catppuccin Mocha)
theme = Catppuccin Mocha
background = #000000

# Font (matches VSCode Monaspace)
font-family = "Monaspace Neon NF"
font-size = 13

# Keybindings (no spaces around = between trigger and action)
# cmd+t and cmd+w are defaults - explicitly setting them causes InvalidAction
keybind = cmd+n=new_window
keybind = cmd+shift+w=close_window
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+Digit1=goto_tab:1
keybind = cmd+Digit2=goto_tab:2
keybind = cmd+Digit3=goto_tab:3
keybind = cmd+Digit4=goto_tab:4
keybind = cmd+Digit5=goto_tab:5
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = cmd+shift+r=reload_config
keybind = cmd+shift+0=reset_font_size
keybind = cmd+f=toggle_fullscreen
